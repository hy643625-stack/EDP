{
  "name": "everydayperfect-frontend",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "doctor:frontend": "node scripts/check-esbuild-runtime.mjs",
    "pretest": "node scripts/check-node-version.mjs",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "pretest:watch": "node scripts/check-node-version.mjs",
    "test:watch": "node ./node_modules/vitest/vitest.mjs"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "dayjs": "^1.11.13",
    "lucide-react": "^0.510.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^5.4.11",
    "vitest": "^1.6.1"
  }
}
